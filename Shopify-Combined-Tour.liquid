<style>
/* -------------------------------------------
   Daikoku PA Tour Custom Layout
   ------------------------------------------- */
#daikoku-tour-template {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  color: #fff;
  background-color: #0b0b0b; /* Enforce dark background */
  padding: 20px 0;
  line-height: 1.6;
}

#daikoku-tour-template * {
  box-sizing: border-box;
}

#daikoku-tour-template h2, 
#daikoku-tour-template h3, 
#daikoku-tour-template h4 {
  color: #fff;
  margin-top: 0;
  margin-bottom: 15px;
  font-weight: 600;
  letter-spacing: 0.5px;
}

#daikoku-tour-template .tour-section {
  max-width: 900px;
  margin: 0 auto 30px;
  padding: 0 15px;
}

#daikoku-tour-template .tour-overview-title {
  text-align: center;
  font-size: 28px;
  font-weight: 800;
  font-style: italic;
  margin-bottom: 0px;
  text-transform: uppercase;
  letter-spacing: -0.5px;
  color: #fff;
}
#daikoku-tour-template .tour-overview-subtitle {
  text-align: center;
  color: #aaa;
  margin-bottom: 0px;
  font-size: 15px;
}

/* Horizontal Scroll Container (Tour Overview) */
@keyframes swipeHorizontal {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(5px); }
}
.dh-swipe-indicator {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  color: #aaa;
  font-size: 14px;
  margin-bottom: 0px;
  gap: 5px;
}
.dh-swipe-indicator svg {
  width: 16px;
  height: 16px;
  fill: currentColor;
  animation: swipeHorizontal 1.5s infinite ease-in-out;
}

.dh-carousel-container {
  display: flex;
  overflow-x: auto;
  gap: 15px;
  padding: 5px 15px 20px;
  margin: 0 -15px;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; /* Firefox */
}
.dh-carousel-container::-webkit-scrollbar {
  display: none; /* Chrome, Safari */
}

.dh-carousel-item {
  flex: 0 0 255px;
  scroll-snap-align: start;
  background: #111;
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border: 1px solid #222;
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

.dh-carousel-image {
  width: 100%;
  aspect-ratio: 3/4;
  background-color: #333; /* Placeholder gray color */
  display: flex;
  align-items: center;
  justify-content: center;
  color: #888;
  font-size: 14px;
}

.dh-carousel-content {
  padding: 15px;
  flex-grow: 1;
}
.dh-carousel-content h4 {
  font-size: 18px;
  color: #fff;
  margin-bottom: 0px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.dh-step-number {
  background: #E50914; /* Accent Red */
  color: white;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: bold;
}
.dh-carousel-content p {
  color: #aaa;
  font-size: 14px;
  margin: 0;
}

/* Grid Sections */
.dh-grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}
@media (max-width: 768px) {
  .dh-grid-2 {
    grid-template-columns: 1fr;
  }
}

.dh-card {
  background: #111;
  border-radius: 12px;
  padding: 20px;
  border: 1px solid #222;
}
.dh-card h3 {
  margin-top: 0;
  margin-bottom: 15px;
  font-size: 22px;
  font-weight: bold;
  color: #ccc;
  border-bottom: 1px solid #333;
  padding-bottom: 10px;
}

/* Pricing Row */
.dh-price-grid {
  display: grid;
  grid-template-columns: 100px 1fr 1fr;
  gap: 10px;
  margin-bottom: 10px;
  align-items: center;
  border-bottom: 1px dashed #222;
  padding-bottom: 8px;
}
.dh-price-grid:last-child {
  border-bottom: none;
}
.dh-price-label {
  font-weight: 500;
  color: #eee;
}
.dh-price-val {
  font-size: 16px;
  font-weight: bold;
  color: #E50914; /* Accent Red */
  text-align: right;
}
.dh-price-sub {
  display: block;
  font-size: 12px;
  color: #888;
  font-weight: normal;
  margin-top: 4px;
}

/* Lists */
.dh-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.dh-list li {
  position: relative;
  padding-left: 15px;
  margin-bottom: 5px;
  color: #ccc;
  font-size: 14px;
}
.dh-list li::before {
  content: '•';
  color: #E50914;
  position: absolute;
  left: 0;
  top: 0;
  font-weight: bold;
}

/* Note Box */
.dh-note-box {
  background: rgba(229, 9, 20, 0.05);
  border-left: 4px solid #E50914;
  padding: 20px;
  border-radius: 0 8px 8px 0;
  margin-top: 30px;
}
.dh-note-box p {
  margin: 0;
  color: #ddd;
  font-size: 14px;
}

/* HERO */
.hero {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  height: 70vh;
  min-height: 500px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background-color: #000;
  margin-bottom: 50px;
}

.hero-bg-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-overlay-gradient {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.8) 80%, #000 100%);
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 20px;
  max-width: 900px;
}

.hero h1 {
  font-size: 4rem;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -2px;
  margin: 0 0 10px;
  color: #fff;
  text-shadow: 0 10px 30px rgba(0, 0, 0, 0.8);
  font-style: italic;
}

.hero p {
  font-size: 1.5rem;
  color: #ccc;
  margin-bottom: 30px;
  font-weight: 300;
}

.btn {
  display: inline-block;
  padding: 15px 40px;
  background: #E60012;
  color: #fff;
  font-weight: 900;
  text-transform: uppercase;
  text-decoration: none;
  letter-spacing: 1px;
  border-radius: 4px;
  transition: transform 0.2s, background 0.2s;
  box-shadow: 0 5px 20px rgba(230, 0, 18, 0.4);
  border: none;
  cursor: pointer;
}

.btn:hover {
  background: #ff1a2e;
  transform: scale(1.05);
}

@media (max-width: 768px) {
  .hero h1 { font-size: 2.5rem; }
  .hero p { font-size: 1.1rem; }
}
  /* Mobile Typography Enhancements */
  @media (max-width: 768px) {
    #daikoku-tour-template .dh-list li,
