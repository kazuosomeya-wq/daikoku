rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 予約データ: 読み込み・更新・削除は管理者のみ。作成(create)はゲスト(全員)可能
    match /bookings/{docId} {
      allow read, update, delete: if request.auth != null;
      allow create: if true;
    }
    // 車両データ: 読み取りは全員、書き込みは認証済みのみ（ただしdriverEmailの更新のみゲストも可能）
    match /vehicles/{docId} {
      allow read: if true;
      allow update: if request.auth != null || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['driverEmail']);
      allow create, delete: if request.auth != null;
    }
    // 設定データ: 読み取りは全員、書き込みは認証済みユーザーのみ
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // プロモコード: 読み取りは全員。使用回数の更新(update)はゲストも可能。
    match /promoCodes/{docId} {
      allow read, update: if true;
      allow create, delete: if request.auth != null;
    }
    // ドライバー空き管理: 読み取りは全員。予約時の枠消費(update)と初期作成(create)はゲストも可能。
    match /vehicle_availability/{docId} {
      allow read, update, create: if true;
      allow delete: if request.auth != null;
    }
    // adminSettings: 認証済みユーザーのみ
    match /adminSettings/{docId} {
      allow read, write: if request.auth != null;
    }
    // その他のコレクション: デフォルト拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
